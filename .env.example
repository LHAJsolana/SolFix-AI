DATABASE_URL=
# Supabase/Vercel integration users: map POSTGRES_PRISMA_URL to DATABASE_URL for runtime.
# Use POSTGRES_URL_NON_POOLING locally for production migration commands when needed.
PERSISTENCE_MODE=local-file
NEXT_PUBLIC_APP_URL=http://localhost:3000

SOLANA_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

AI_PROVIDER=deterministic
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

ENABLE_AI_EXPLANATIONS=false
ENABLE_WALLET_ATTESTATION=true
ENABLE_CUSTOM_RPC=false

RATE_LIMIT_MODE=memory

LOCAL_REPORT_STORE_FILE=solfix-reports.json

NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_EXPLORER_BASE_URL=https://explorer.solana.com
